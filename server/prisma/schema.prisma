generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Request {
  id          Int      @id @default(autoincrement())
  title       String
  clientName  String   @map("client_name")
  email       String?
  description String?
  status      String   @default("New")
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("requests")
}
